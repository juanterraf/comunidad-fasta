# /etc/nginx/sites-available/comunidad-fasta
# Apuntar el dominio (comunidad-fasta.example.com) al server.
# Luego: sudo ln -s /etc/nginx/sites-available/comunidad-fasta /etc/nginx/sites-enabled/
#        sudo nginx -t && sudo systemctl reload nginx
#        sudo certbot --nginx -d comunidad-fasta.example.com

# CSP — leaflet carga tiles desde *.tile.openstreetmap.org, por eso van
# en img-src + connect-src. Si en algún momento sumás Plausible self-hosted,
# agregalo a script-src y connect-src.
# 'unsafe-inline' en script-src es necesario para los bootstrap inline de Next.
# Si querés endurecerlo más, configurá nonces desde middleware y reemplazá
# 'unsafe-inline' por 'nonce-...'.
map $sent_http_content_type $cf_csp {
    default "";
    ~^text/html "default-src 'self'; base-uri 'self'; form-action 'self'; frame-ancestors 'none'; img-src 'self' data: blob: https://*.tile.openstreetmap.org; font-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'; connect-src 'self' https://*.tile.openstreetmap.org; object-src 'none'";
}

server {
    listen 80;
    listen [::]:80;
    server_name comunidad-fasta.example.com;

    # Certbot mete acá el bloque SSL automáticamente al correr `certbot --nginx`.
    # A continuación deja un 301 a https.

    # Tamaño máximo de upload (la app ya limita por env, esto es un techo).
    client_max_body_size 12m;

    # Headers de seguridad globales del server. `always` los aplica incluso en 4xx/5xx.
    add_header Content-Security-Policy $cf_csp always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header X-Frame-Options "DENY" always;
    add_header Referrer-Policy "same-origin" always;
    add_header Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=(), usb=()" always;
    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;

    # NO setear X-Robots-Tag: noindex en el header HTTP. Aunque queremos
    # noindex para buscadores, los crawlers de Facebook/WhatsApp/Twitter
    # también respetan este header y abortan la generación de preview
    # ANTES de leer el HTML. Resultado: links compartidos en redes
    # aparecen sin título ni imagen.
    # El noindex queda cubierto por:
    #   - src/app/layout.tsx: robots: { index: false, follow: false }
    #     (emite <meta name="robots" content="noindex, nofollow">)
    #   - src/app/robots.ts: Disallow: / para *, Allow: / para los
    #     bots de social media.

    location / {
        proxy_pass http://127.0.0.1:3000;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_read_timeout 60s;
    }

    # Cache largo para imágenes servidas por la API
    location ~* ^/api/image/ {
        proxy_pass http://127.0.0.1:3000;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-Proto $scheme;
        add_header Cache-Control "public, max-age=2592000, immutable" always;
        add_header X-Content-Type-Options "nosniff" always;
    }
}
